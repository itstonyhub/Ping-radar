Ωimport { NextResponse } from "next/server";

type ApiTweet = {
  id: string;
  text: string;
  created_at: string;
  author_id: string;

  author_username: string | null;
  author_name: string | null;
  author_profile_image_url: string | null;
  author_verified: boolean;

  url: string;
};


function clamp(n: number, min: number, max: number) {
  return Math.max(min, Math.min(max, n));
}

export async function GET(req: Request) {
  try {
    const token = process.env.X_BEARER_TOKEN;
    if (!token) {
      return NextResponse.json(
        { ok: false, error: "Missing X_BEARER_TOKEN in .env.local" },
        { status: 500 }
      );
    }

    const { searchParams } = new URL(req.url);
    const limit = clamp(Number(searchParams.get("limit") ?? "20"), 10, 100);

    // FEED “BUONO” (segnali): snapshot/allocation/eligibility/claim live ecc.
    // + esclusioni “scam/giveaway/fuffa”
    const query =
  '(snapshot OR allocation OR eligibility OR eligible OR "check eligibility" OR "check allocation" OR "claim live" OR "claim now" OR "claim opens")' +
  ' -(giveaway OR winner OR won OR congratulations OR "dm me" OR "send me a dm" OR follow OR retweet OR "like and retweet" OR "join now" OR cashapp OR whatsapp OR telegram OR "wallet address")' +
  ' -is:retweet -is:reply lang:en';
const q = query.replace(/\s+/g, ' ').trim();



   

    // ✅ QUI era il tuo bug: url non definita. La ricreiamo SEMPRE.
const url =
  "https://api.x.com/2/tweets/search/recent?" +
  `query=${encodeURIComponent(query)}` +
  `&max_results=${limit}` +
  `&tweet.fields=created_at,author_id` +
  `&expansions=author_id` +
  `&user.fields=username,name,profile_image_url,verified`;



    const res = await fetch(url, {
      headers: { Authorization: `Bearer ${token}` },
      cache: "no-store",
    });

    const raw = await res.text();
    let json: any = null;

    try {
      json = JSON.parse(raw);
    } catch {
      return NextResponse.json(
        { ok: false, status: res.status, error: "X returned invalid JSON", raw },
        { status: 500 }
      );
    }

    if (!res.ok) {
      return NextResponse.json(
        { ok: false, status: res.status, data: json },
        { status: res.status }
      );
    }

      
// Join tweet -> user (from includes.users)
const users = json?.includes?.users ?? [];
const usersById = new Map<string, any>(users.map((u: any) => [u.id, u]));

const tweets: ApiTweet[] = (json?.data ?? []).map((t: any) => {
  const u = usersById.get(t.author_id);

  return {
    id: t.id,
    text: t.text,
    created_at: t.created_at,
    author_id: t.author_id,

    author_username: u?.username ?? null,
    author_name: u?.name ?? null,
    author_profile_image_url: u?.profile_image_url ?? null,
    author_verified: u?.verified ?? false,

    // utile per il bottone "Open on X"
    url: `https://x.com/${u?.username ?? "i"}/status/${t.id}`,
  };
});



    // Extra safety: filtra a runtime eventuali “giveaway” scappati
    const cleaned = tweets.filter((t) => {
      const s = (t.text ?? "").toLowerCase();
      return !(
        s.includes("giveaway") ||
        s.includes("like and retweet") ||
        s.includes("dm me") ||
        s.includes("send me a dm") ||
        s.includes("randomly selected")
      );
    });

    return NextResponse.json({
      ok: true,
      status: 200,
      query,
      count: cleaned.length,
      tweets: cleaned,
      updatedAt: new Date().toISOString(),
    });
  } catch (e: any) {
    return NextResponse.json(
      { ok: false, error: e?.message ?? "Unknown error" },
      { status: 500 }
    );
  }
}

